# Backend
APP_NAME=turkiye-otomat-ihale-takip
ENVIRONMENT=dev
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tender_tracker

AUTH_DISABLED=false
AUTH_SECRET_KEY=change-this-secret-in-production
AUTH_TOKEN_TTL_MINUTES=720
ADMIN_TOKEN=admin-token
ANALYST_TOKEN=analyst-token
VIEWER_TOKEN=viewer-token

SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=30
AUTO_PURGE_MOCK_DATA=true

SCORING_HIGH_THRESHOLD=75
SCORING_RELEVANT_THRESHOLD=55
SCORING_MAYBE_THRESHOLD=35
NOTIFICATION_SCORE_THRESHOLD=80

NOTIFICATION_COOLDOWN_MINUTES=120
DEADLINE_WARNING_DAYS=14,7,3

EMAIL_ENABLED=false
EMAIL_FROM=alerts@example.com
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_RECIPIENTS=team@example.com

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seed script options
SEED_INCLUDE_MOCK_SOURCES=false

# Frontend
# Mümkünse tam adres kullanın: http://localhost:8000/api/v1
NEXT_INTERNAL_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# İsteğe bağlı: statik fallback token (genelde boş bırakın, login ile cookie token kullanılır)
NEXT_PUBLIC_API_TOKEN=

# Seed script
# Varsayılan kullanıcı şifresi
SEED_DEFAULT_PASSWORD=Otomat123!
